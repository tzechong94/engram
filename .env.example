# ───────────────────────────────────────────────────────────────────────────
# Engram environment. Copy to .env and fill in. Everything is config-driven so
# the same code runs locally (docker-compose) or on Alibaba Cloud (swap values).
# ───────────────────────────────────────────────────────────────────────────

# ── Qwen / Model Studio (DashScope) ─────────────────────────────────────────
# Get a key at https://bailian.console.aliyun.com (Model Studio).
# >>> WIRE-IN POINT: drop your key here and everything uses real Qwen. <<<
# Until then, leave QWEN_MOCK=true and the system runs on a deterministic mock
# (embeddings + canned consolidation) so tests and the eval harness pass offline.
DASHSCOPE_API_KEY=
QWEN_MOCK=true
# DashScope OpenAI-compatible base URL (clients hit this directly, no middle layer)
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Model IDs (confirm against Model Studio; these are the documented defaults)
QWEN_CHAT_MODEL=qwen-max
QWEN_TURBO_MODEL=qwen-turbo
QWEN_EMBED_MODEL=text-embedding-v3
QWEN_EMBED_DIM=1024
QWEN_RERANK_MODEL=gte-rerank
QWEN_VL_MODEL=qwen-vl-max

# ── Storage: Postgres + pgvector (local) ↔ AnalyticDB for PostgreSQL (cloud) ──
DATABASE_URL=postgres://engram:engram@localhost:5433/engram

# ── Hot tier / queue: Redis (local) ↔ Tair (cloud) ──────────────────────────
REDIS_URL=redis://localhost:6380

# ── Blob / cold archive: MinIO (local, S3-compatible) ↔ OSS (cloud) ─────────
BLOB_ENDPOINT=http://localhost:9000
BLOB_ACCESS_KEY=engram
BLOB_SECRET_KEY=engrampassword
BLOB_BUCKET=engram-archive
BLOB_REGION=us-east-1

# ── Infra selection (which interface impl to load) ──────────────────────────
# local | alibaba — flips Store/Vector/Blob/Queue/Scheduler/Secrets impls.
ENGRAM_INFRA=local

# ── Sleep phase ─────────────────────────────────────────────────────────────
# Per-tenant cost ceiling per cycle (USD cents). Cycle stops cleanly when hit.
SLEEP_COST_CAP_CENTS=50
# Nightly schedule (cron) + inactivity trigger (minutes), whichever first.
SLEEP_CRON=0 4 * * *
SLEEP_INACTIVITY_MINUTES=120
# Forget sweep: episodes below this decayed-importance are archived/forgotten.
FORGET_THRESHOLD=0.15
# Reflection trigger: fire a sleep cycle once accumulated episode importance since
# the last cycle exceeds this (Generative Agents). 0 disables.
SLEEP_IMPORTANCE_THRESHOLD=15

# ── Encryption at rest (memory content) ─────────────────────────────────────
# 32-byte hex key for AES-256-GCM field encryption of episode/note content.
ENGRAM_ENCRYPTION_KEY=

