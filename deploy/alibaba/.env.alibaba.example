# Engram on Alibaba Cloud — config swap. Copy to .env.alibaba and fill in.
ENGRAM_INFRA=alibaba

# Qwen via Model Studio / DashScope (same API local and cloud)
DASHSCOPE_API_KEY=
QWEN_MOCK=false
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-max
QWEN_TURBO_MODEL=qwen-turbo
QWEN_EMBED_MODEL=text-embedding-v3
QWEN_EMBED_DIM=1024
QWEN_RERANK_MODEL=gte-rerank

# AnalyticDB for PostgreSQL (pgvector). Enable the vector extension on the instance.
DATABASE_URL=postgres://<user>:<pass>@<adbpg-endpoint>:5432/engram

# Tair (Redis-compatible)
REDIS_URL=redis://<tair-endpoint>:6379

# OSS (S3-compatible) — cold archive of forgotten/superseded memory (encrypted)
BLOB_ENDPOINT=https://oss-<region>.aliyuncs.com
BLOB_ACCESS_KEY=
BLOB_SECRET_KEY=
BLOB_BUCKET=engram-archive
BLOB_REGION=<region>

# Encryption at rest — REQUIRED in cloud. 32-byte hex (KMS-managed).
ENGRAM_ENCRYPTION_KEY=

# Sleep phase
SLEEP_COST_CAP_CENTS=50
SLEEP_CRON=0 4 * * *
SLEEP_INACTIVITY_MINUTES=120
FORGET_THRESHOLD=0.15
